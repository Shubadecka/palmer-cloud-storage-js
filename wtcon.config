<VirtualHost *:443>
    # Basic Information about the server
    ServerName localhost
    ServerAlias www.wtconservatory.com
    ServerAdmin admin@wtconservatory.com

    # Logging details
    ErrorLog ${APACHE_LOG_DIR}/wtc_error.log
    CustomLog ${APACHE_LOG_DIR}/wtc_access.log combined
    # LogFormat "%h %l %u %t \"%r\" %>s %b \"%{Referer}i\" \"%{User-Agent}i\"" combined
    # LogFormat "%{X-Forwarded-For}i %l %u %t \"%r\" %>s %b \"%{Referer}i\" \"%{User-Agent}i\"" proxy
    # SetEnvIf X-Forwarded-For "^.*\..*\..*\..*" forwarded
    # CustomLog "logs/access_log" combined env=!forwarded
    # CustomLog "logs/access_log" proxy env=forwarded

    # Certificate Configuration
    SSLEngine on
    SSLCertificateFile /etc/ssl/certs/zerosslwtcom.crt
    SSLCertificateKeyFile /etc/ssl/private/zerosslwtcom_private.key
    SSLCACertificateFile /etc/ssl/ca/zerosslwtcom_ca.crt

    # Document root for serving the main landing page
    DocumentRoot /var/www/html/palmer-cloud
    <Directory /var/www/html/palmer-cloud>
        Options Indexes FollowSymLinks
        AllowOverride None
        Require all granted
    </Directory>

    # Proxy for ownCloud - handle all ownCloud paths
    ProxyPass /ownCloud/ http://localhost:1449/
    ProxyPassReverse /ownCloud/ http://localhost:1449/
    
    # Handle ownCloud redirects that don't include the subdirectory
    ProxyPass /login http://localhost:1449/login
    ProxyPassReverse /login http://localhost:1449/login
    ProxyPass /apps/ http://localhost:1449/apps/
    ProxyPassReverse /apps/ http://localhost:1449/apps/
    ProxyPass /core/ http://localhost:1449/core/
    ProxyPassReverse /core/ http://localhost:1449/core/
    ProxyPass /index.php http://localhost:1449/index.php
    ProxyPassReverse /index.php http://localhost:1449/index.php
    
    ProxyPreserveHost On

    # Proxy for PiHole
    ProxyPass /pihole http://10.0.0.182/admin/
    ProxyPassReverse /pihole http://10.0.0.182/admin/

    # Handle WebSocket connections for ownCloud
    # RewriteEngine On
    # RewriteCond %{HTTP:Upgrade} =websocket [NC]
    # RewriteRule ^/ownCloud/(.*) ws://localhost:1449/$1 [P,L]

    # Handle regular HTTP connections for ownCloud
    # RewriteEngine On
    # RewriteCond %{HTTP:Upgrade} !=websocket [NC]
    # RewriteRule ^/ownCloud/(.*) http://localhost:1449/$1 [P,L]

    # ownCloud headers for subdirectory handling
    <Location /ownCloud/>
        RequestHeader set X-Forwarded-Proto "https"
        RequestHeader set X-Forwarded-Host "wtconservatory.com"
        RequestHeader set X-Forwarded-For "%{REMOTE_ADDR}s"
        RequestHeader set X-Forwarded-Prefix "/ownCloud"
    </Location>
    
    # Rewrite ownCloud redirects to include subdirectory
    ProxyPassReverse / http://localhost:1449/
    ProxyPassReverse /ownCloud/ http://localhost:1449/
</VirtualHost>
